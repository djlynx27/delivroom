{
  "packageId": "app.delivroom.driver",
  "host": "delivroom.vercel.app",
  "name": "Delivroom — Chauffeur",
  "launcherName": "Delivroom",
  "display": "standalone",
  "themeColor": "#0A0A1A",
  "themeColorDark": "#000000",
  "navigationColor": "#0A0A1A",
  "navigationColorDark": "#0A0A1A",
  "navigationDividerColor": "#0A0A1A",
  "navigationDividerColorDark": "#0A0A1A",
  "backgroundColor": "#0A0A1A",
  "enableNotifications": true,
  "startUrl": "/",
  "iconUrl": "https://delivroom.vercel.app/pwa-icon-512.png",
  "maskableIconUrl": "https://delivroom.vercel.app/pwa-icon-512.png",
  "monochromeIconUrl": "https://delivroom.vercel.app/pwa-icon-512.png",
  "splashScreenFadeOutDuration": 300,
  "signingKey": {
    "path": "./android.keystore",
    "alias": "delivroom"
  },
  "appVersionName": "1.1.0",
  "appVersionCode": 3,
  "shortcuts": [
    {
      "name": "Aujourd'hui",
      "shortName": "Aujourd'hui",
      "url": "/",
      "chosenIconUrl": "https://delivroom.vercel.app/pwa-icon-192.png"
    },
    {
      "name": "Mes revenus",
      "shortName": "Revenus",
      "url": "/revenue",
      "chosenIconUrl": "https://delivroom.vercel.app/pwa-icon-192.png"
    }
  ],
  "shareTarget": {
    "action": "/share-import",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "files",
          "accept": ["image/jpeg", "image/png", "image/webp", "image/*"]
        }
      ]
    }
  },
  "generatorApp": "bubblewrap-cli",
  "fallbackType": "chromeos",
  "features": {},
  "alphaDependencies": {
    "enabled": false
  },
  "enableSiteSettingsShortcut": true,
  "isChromeOSOnly": false,
  "isMetaQuest": false,
  "minSdkVersion": 21,
  "orientation": "portrait",
  "fingerprints": [],
  "additionalTrustedOrigins": [],
  "retainedBundles": [],
  "displayOverride": [],
  "appVersion": "1.1.0"
}