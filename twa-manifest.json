{
  "packageId": "app.delivroom.driver",
  "host": "delivroom.vercel.app",
  "name": "Delivroom — Chauffeur",
  "launcherName": "Delivroom",
  "display": "standalone",
  "orientation": "portrait",
  "themeColor": "#0a0a1a",
  "navigationColor": "#0a0a1a",
  "navigationColorDark": "#0a0a1a",
  "navigationDividerColor": "#0a0a1a",
  "navigationDividerColorDark": "#0a0a1a",
  "backgroundColor": "#0a0a1a",
  "enableNotifications": true,
  "startUrl": "/",
  "iconUrl": "https://delivroom.vercel.app/pwa-icon-512.png",
  "maskableIconUrl": "https://delivroom.vercel.app/pwa-icon-512.png",
  "monochromeIconUrl": "https://delivroom.vercel.app/pwa-icon-512.png",
  "shortcuts": [
    {
      "name": "Aujourd'hui",
      "shortName": "Aujourd'hui",
      "url": "/",
      "icons": [
        {
          "src": "https://delivroom.vercel.app/pwa-icon-192.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Mes revenus",
      "shortName": "Revenus",
      "url": "/revenue",
      "icons": [
        {
          "src": "https://delivroom.vercel.app/pwa-icon-192.png",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "appVersion": "1.0.0",
  "appVersionCode": 1,
  "signingKey": {
    "path": "./android.keystore",
    "alias": "delivroom"
  },
  "splashScreenFadeOutDuration": 300,
  "fallbackType": "chromeos",
  "features": {},
  "alphaDependencies": {
    "enabled": false
  },
  "enableSiteSettingsShortcut": true,
  "isChromeOSOnly": false,
  "isMetaQuest": false,
  "fullyImmersive": false,
  "minSdkVersion": 21,
  "targetSdkVersion": 34
}
